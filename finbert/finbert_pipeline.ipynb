    "print(\"Repo ready.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "g7h8i9j0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install dependencies (uv not available in Colab — use pip directly)\n",
