    "print(f\"Output directory: {OUTPUT_DIR}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f6g7h8i9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Clone repo (skip if already cloned)\n",
    "import os\n",
    "\n",
    "REPO_DIR = \"/content/Earnings-Call-Sentiment-Analysis-FinBERT-vs.-Naive-Bayes-LR-TF-IDF\"\n",
    "\n",
